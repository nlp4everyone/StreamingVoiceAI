# ─────────────────────────────────────────────────────────────────────────────
# Environment-specific config — copy to .env and fill in your values.
# These override anything in config/settings.yaml.
# ─────────────────────────────────────────────────────────────────────────────

# NeMo ASR endpoint
NEMO_API_URL=http://172.17.0.1:8005/v1/audio/transcriptions

# VAD model path (differs between local dev and Docker)
VAD_MODEL_PATH=/app/models/silero_vad.onnx
VAD_USE_INT8=false          # true to prefer INT8 quantized model

# Inference device
STT_DEVICE=cuda             # cuda | cpu

# Concurrency — tune to match available hardware
ASR_SEMAPHORE_LIMIT=8       # max concurrent NeMo HTTP requests
VAD_POOL_SIZE=8             # parallel VAD instances; match ASR_SEMAPHORE_LIMIT

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

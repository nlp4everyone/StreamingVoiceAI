FROM python:3.11-slim

WORKDIR /app

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Ho_Chi_Minh

# =============================================================================
# System Dependencies
# =============================================================================
RUN apt-get update && apt-get install -y \
    build-essential \
    tzdata \
    ffmpeg \
    wget \
    && rm -rf /var/lib/apt/lists/* \
    && ln -fs /usr/share/zoneinfo/$TZ /etc/localtime \
    && dpkg-reconfigure --frontend noninteractive tzdata

# =============================================================================
# Dependencies Installation
# =============================================================================
COPY requirements/requirements_core.txt /app/requirements/requirements_core.txt
COPY requirements/requirements_component.txt /app/requirements/requirements_component.txt

RUN pip install --upgrade pip setuptools wheel
RUN pip install -r /app/requirements/requirements_core.txt
RUN pip install -r /app/requirements/requirements_component.txt

# =============================================================================
# Model Cache
# Download SileroVAD ONNX model directly into the image layer so runtime
# startup needs no internet access. Placed before COPY . so source changes
# don't bust this layer.
# =============================================================================
RUN mkdir -p /app/models && \
    wget -q -O /app/models/silero_vad.onnx \
    "https://github.com/snakers4/silero-vad/raw/master/src/silero_vad/data/silero_vad.onnx"

# =============================================================================
# Application
# =============================================================================
COPY . /app

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
